  "actions": [
    {
      "id": "checkin",
      "params": ["roomNo", "guestName", "stayDays"],
      "preconditions": ["room.requiresRoomLevel <= facilities.room", "객실 정원 미달"],
      "effects": ["방 점유 추가(잔여박수=stayDays)", "gold += room.pricePerNight * stayDays (선불)"]
    },
    {
      "id": "checkout",
      "params": ["roomNo", "guestName"],
      "preconditions": ["해당 방에 해당 투숙객 존재"],
      "effects": ["방 점유 제거", "환불 없음(선불)"]
    },
    {
      "id": "sale",
      "params": ["menuName", "qty"],
      "preconditions": ["메뉴가 kitchen 레벨 내", "resources[consumes] >= qty"],
      "effects": ["gold += price*qty", "resources[consumes] -= qty"]
    },
    {
      "id": "purchase",
      "params": ["resourceId", "qty"],
      "preconditions": ["gold >= basePrice*qty"],
      "effects": ["gold -= basePrice*qty", "resource += qty"]
    },
    {
      "id": "hire",
      "params": ["npcId", "dailyWage"],
      "preconditions": ["임금 합의 완료(LLM 판정)", "staff.length < staffMax(quarters)"],
      "effects": ["staff 추가 {npcId, dailyWage}"]
    },
    {
      "id": "fire",
      "params": ["npcId"],
      "preconditions": ["재직 중"],
      "effects": ["staff 제거 (스탯 보존)"]
    }
  ],

  "formulas": [
